AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000201 "A census about contaminated things of a given type in an area of interest."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000201 "A census about contaminated things of a given type in an area of interest."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000201 "ContaminatedThingCensus")
