AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000368 "Example: Hamiltonella defensa and aphids"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000368 "facultative endosymbiotic mutualism"@en)
EquivalentClasses(obo:APOLLO_SV_00000368 ObjectIntersectionOf(obo:APOLLO_SV_00000367 ObjectSomeValuesFrom(obo:BFO_0000055 ObjectIntersectionOf(obo:APOLLO_SV_00002024 ObjectSomeValuesFrom(obo:BFO_0000054 obo:APOLLO_SV_00000372) ObjectSomeValuesFrom(obo:RO_0000052 obo:OBI_0100026)))))
SubClassOf(obo:APOLLO_SV_00000368 obo:APOLLO_SV_00000367)

