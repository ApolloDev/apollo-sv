# Class: obo:APOLLO_SV_00000244 (disease unique identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000244 "a unique identifier that refers to a disease."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000244 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000244 "A unique identifier that refers to a particular type of disease."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000244 "This class is different from its superclass, in that the identifier is non-redundant with other identifiers in its context (such as a coding system or terminology or ontology).  The superclass admits of natural langugage names of diseases, whereas this one typically does not."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000244 "We still need to decide which coding schema to adopt.-MB"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000244 "disease unique identifier"@en)
SubClassOf(obo:APOLLO_SV_00000244 obo:APOLLO_SV_00000598)

# Class: obo:APOLLO_SV_00000245 (conditional probability distribution)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000245 "A probability distribution of two jointly distributed random variables X and Y, where Y is know to be a particular value."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000245 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000245 "A probability distribution of two jointly distributed random variables X and Y, where Y is know to be a particular value."@en)
