AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000245 "conditional probability distribution"@en)
SubClassOf(obo:APOLLO_SV_00000245 obo:APOLLO_SV_00000215)

# Class: obo:APOLLO_SV_00000246 (joint probability distribution)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000246 "In the study of probability, given at least two random variables X, Y, ..., that are defined on a probability space, the joint probability distribution for X, Y, ... is a probability distribution that gives the probability that each of X, Y, ... falls in any particular range or discrete set of values specified for that variable."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000246 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000119 obo:APOLLO_SV_00000246 "http://en.wikipedia.org/w/index.php?title=Joint_probability_distribution&oldid=599692661"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000246 "In the study of probability, given at least two random variables X, Y, ..., that are defined on a probability space, the joint probability distribution for X, Y, ... is a probability distribution that gives the probability that each of X, Y, ... falls in any particular range or discrete set of values specified for that variable."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000246 "joint probability distribution"@en)
SubClassOf(obo:APOLLO_SV_00000246 obo:APOLLO_SV_00000215)

# Class: obo:APOLLO_SV_00000247 (unconditional probability distribution)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000247 "An unconditional probability distribution is the probability distribution of an uncertain variable, U, implicitly incorporating the uncertainty introduced by any other relevant variables. Mathematically, U’s unconditional probability distribution is written {U | E}, where E represents the background state of information under which the distribution is assessed."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000247 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000119 obo:APOLLO_SV_00000247 "http://grahamjeffery.com/glossary/213-unconditional-probability-distribution"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000247 "An unconditional probability distribution is the probability distribution of an uncertain variable, U, implicitly incorporating the uncertainty introduced by any other relevant variables. Mathematically, U’s unconditional probability distribution is written {U | E}, where E represents the background state of information under which the distribution is assessed."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000247 "UnconditionalProbabilityDistribution")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000247 "unconditional probability distribution"@en)
SubClassOf(obo:APOLLO_SV_00000247 obo:APOLLO_SV_00000215)

