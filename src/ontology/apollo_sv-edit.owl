# Class: obo:APOLLO_SV_00000209 (infected organism)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000209 "organism in latent period of infection"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000209 "An infectious agent host who is NOT able to transmit the infection to another organism of the same species."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000209 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000209 "An infected organism of a particular species that is not yet able to transmit the infection to a susceptible organism of a particular species.

Note that the infected and sucseptible organisms may be of different species."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000209 "infected")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000209 "infected organism"@en)
EquivalentClasses(obo:APOLLO_SV_00000209 ObjectIntersectionOf(obo:APOLLO_SV_00000238 ObjectComplementOf(ObjectSomeValuesFrom(obo:RO_0000091 obo:APOLLO_SV_00000182))))
