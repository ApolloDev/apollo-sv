AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000570 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000570 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000570 "A data item that denotes some context in which an individual realizes some employee role if he or she is a member of the labor force, or the context in which he or she is not a member of the labor force according to certain prespecified conditions."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000570 "employmentStatus")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000570 "If an individual is a member of the labor force, the criteria that this status is selected from includes whether they are in the armed forces, employed and working, employed but absent from work for a week, and unemployed. The criteria for those not in the labor force includes whether the individual is a houseworker, suffering from a physical impairment that prevents them from working, in school, or other miscellaneous reasons."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000570 "employment status data item"@en)
SubClassOf(obo:APOLLO_SV_00000570 obo:IAO_0000027)

# Class: obo:APOLLO_SV_00000571 (contaminated abiotic thing)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000571 "An abiotic ecosystem element that is participant in some biological contamination process."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000571 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000571 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000571 "An abiotic ecosystem element that is participant in some biological contamination process."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000571 "contaminatedAbioticThing")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000571 "contaminated abiotic thing"@en)
SubClassOf(obo:APOLLO_SV_00000571 obo:APOLLO_SV_00000220)

# Class: obo:APOLLO_SV_00000572 (odor-baited trap control strategy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000572 "An adult vector control strategy that has 1) an action specification that is realized by the use of mosquito traps that leverage natural or synthetic human odors as bait, and 2) an objective specification that is realized by preventing potentially infectious contacting between some mosquito vector and some human host."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000572 "Matthew Diller"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000572 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000572 "An adult vector control strategy that has 1) an action specification that is realized by the use of mosquito traps that leverage natural or synthetic human odors as bait, and 2) an objective specification that is realized by preventing potentially infectious contacting between some mosquito vector and some human host."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000572 "odor-baited trap control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000572 obo:APOLLO_SV_00000414)

# Class: obo:APOLLO_SV_00000573 (zoo-prophylaxis control strategy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000573 "An infectious disease control strategy that attempts to prevent infection of susceptible human host organisms in a particular geographical region by increasing the population of domesticated animals in that region, such that less mosquitoes feed on humans."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000573 "Matthew Diller"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000573 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000573 "An infectious disease control strategy that attempts to prevent infection of susceptible human host organisms in a particular geographical region by increasing the population of domesticated animals in that region, such that less mosquitoes feed on humans."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000573 "zoo-prophylaxis control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000573 obo:APOLLO_SV_00000086)

# Class: obo:APOLLO_SV_00000574 (acute respiratory illness)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000574 "A clinical phenotype that is causally preceded by some infection or some adverse drug reaction; and that is accompanied by a fever greater than or equal to 37.8 degrees Celsius, and a cough or sore throat."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000574 "Matthew Diller"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000574 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000574 "influenza-like illness"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000574 "acute respiratory illness"@en)
