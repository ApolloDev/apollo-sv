SubClassOf(obo:APOLLO_SV_00000201 obo:APOLLO_SV_00000173)

# Class: obo:APOLLO_SV_00000202 (indexable Apollo item)

AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000202 "ApolloIndexableItem")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000202 "A class representing an abstract type. This class has no attributes and programmers should use it to determine whether an instance should be saved or can be retrieved."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000202 "indexable Apollo item"@en)
SubClassOf(obo:APOLLO_SV_00000202 obo:IAO_0000030)

# Class: obo:APOLLO_SV_00000203 (NCBI taxon identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000203 "A taxonomy identifier curated by the NCBI Taxonomy that designates a biological taxon."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000203 "An identifier curated by the National Center for Biotechnology Information (NCBI) that designates a particular biological taxon (e.g., Homo sapiens).")
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000203 "NcbiTaxonId")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000203 "NCBI taxon identifier"@en)
SubClassOf(obo:APOLLO_SV_00000203 obo:APOLLO_SV_00000509)

# Class: obo:APOLLO_SV_00000204 (disease outcome)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000204 "A processual entity that is either the outcome of a disease course or a part of a disease course and has etiological relevance."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000204 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000204 "An event that happens during the course of a disease and that results from pathological processes that happened earlier in the disease."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000204 "diseaseOutcome")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000204 "The infectious disease type in the XSD has a disease outcome element, which specifies whether someone became symptomatic, was hospitalized, etc.  All of these outcomes require some process to occur.  For sequalae of disease, it is that the realization of the disease is an etiological process that creates some other disorder.  For example, fever is often occurs because of high levels of certain interleukins (which is a disorder).

So I am comfortable with disease outcome as a process.  It is also consistent with the probabilitistic information that will go with it, as a future probability is almost always (if not always) the probability of some event occurring (e.g., coin turning up heads, raining, developing a disease),"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000204 "disease outcome"@en)
SubClassOf(obo:APOLLO_SV_00000204 obo:BFO_0000015)
SubClassOf(obo:APOLLO_SV_00000204 ObjectUnionOf(ObjectSomeValuesFrom(obo:BFO_0000050 obo:OGMS_0000063) ObjectSomeValuesFrom(obo:RO_0002087 obo:OGMS_0000063)))

# Class: obo:APOLLO_SV_00000205 (susceptible organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000205 "An organism that is the bearer of a susceptibility disposition."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000205 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000205 "An organism of a particular species that can undergo infection with a particular pathogen."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000205 "susceptible")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000205 "susceptible organism"@en)
EquivalentClasses(obo:APOLLO_SV_00000205 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000172)))
SubClassOf(obo:APOLLO_SV_00000205 obo:OBI_0100026)

# Class: obo:APOLLO_SV_00000206 (immune organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000206 "An organism that is the bearer of an immune resistance disposition."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000206 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000206 "An organism of a particular species that has developed immune resistance to infection with a pathogen of a particular species."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000206 "immune")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000206 "immune organism"@en)
EquivalentClasses(obo:APOLLO_SV_00000206 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000151)))
SubClassOf(obo:APOLLO_SV_00000206 obo:OBI_0100026)

# Class: obo:APOLLO_SV_00000207 (resistant organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000207 "an organism that is the bearer of resistance to infection"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000207 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000207 "An organism of a particular species that is unable to undergo infection with a particular pathogen."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000207 "resistant")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000207 "resistant organism"@en)
EquivalentClasses(obo:APOLLO_SV_00000207 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000145)))
SubClassOf(obo:APOLLO_SV_00000207 obo:OBI_0100026)

# Class: obo:APOLLO_SV_00000208 (control strategy start time information)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000208 "An information content entity that specifies the start time of the implementation of a infectious disease control strategy."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000208 "A specification of when an infectious disease control strategy starts."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000208 "controlMeasureStartTime")
