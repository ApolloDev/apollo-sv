AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000633 "William R. Hogan"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000633 "cumulative epidemic hospitalization count"@en)
