AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000242 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000242 "An information content entity that specifies a time span on a specified time scale by giving a start time and a duration."@en)
