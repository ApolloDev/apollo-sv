SubClassOf(obo:APOLLO_SV_00000238 obo:OBI_0100026)

# Class: obo:APOLLO_SV_00000239 (infectious disease)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000239 "A disease that inheres in a host and, when realized, is realized as a disease course that is causally preceded by an infection."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000239 "A disease that is caused by an infection."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000239 "InfectiousDisease")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000239 "Infection is the etiological process, as defined by OGMS, for infectious disease.  However, OGMS does not relate its etiological process class to its disorder class as of this writing.  So it is not clear how to connect infectious disease to its infection etiological process."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000239 "infectious disease"@en)
EquivalentClasses(obo:APOLLO_SV_00000239 ObjectIntersectionOf(obo:OGMS_0000031 ObjectAllValuesFrom(obo:BFO_0000054 ObjectIntersectionOf(obo:OGMS_0000063 ObjectSomeValuesFrom(obo:RO_0002404 obo:APOLLO_SV_00000114))) ObjectAllValuesFrom(obo:RO_0000052 obo:APOLLO_SV_00000238)))
SubClassOf(obo:APOLLO_SV_00000239 obo:OGMS_0000031)

