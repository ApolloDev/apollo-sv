# Class: obo:APOLLO_SV_00000640 (cumulative vaccination count)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000640 "A count of vaccinations in a population that is the total number of a given type of vaccines administered during a reference temporal interval.")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000640 "William R. Hogan"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000640 "The reference interval is usually relative to (i.e., occupied by) a major event like an epidemic or vaccination campaign, or it is a specific calendar-defined interval like a given calendar year or a set of consecutive \"epidemiological weeks\" as defined by CDC or another national or subnational public health organization.")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000640 "cumulative vaccination count"@en)
SubClassOf(obo:APOLLO_SV_00000640 obo:APOLLO_SV_00000626)

# Class: obo:APOLLO_SV_00000641 (incident vaccination count)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000641 "A count of vaccinations in a population that is the number of a given type of vaccines administered during a proper occurrent part of a reference temporal interval."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000641 "William R. Hogan"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000641 "The interval over which the count is made is typically either one calendar day or one calendar week. The reference interval is usually relative to (i.e., occupied by) a major event like an epidemic, vaccination campaign, or it is a specific calendar-defined interval like a given calendar year or a set of consecutive \"epidemiological weeks\" as defined by CDC or another national or subnational public health organization."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000641 "incident vaccination count"@en)
SubClassOf(obo:APOLLO_SV_00000641 obo:APOLLO_SV_00000626)

