AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000323 "An infectious disease conrol straegy that seeks to reduce disease transmission by offering employees extra paid time off to stay home, in an attempt to reduce contacts that transmit disease in the workplace."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000323 "LiberalSickLeaveControlMeasure")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000323 "liberal sick leave control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000323 obo:APOLLO_SV_00000086)

