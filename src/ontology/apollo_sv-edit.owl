# Class: obo:APOLLO_SV_00000797 (creating a copyright license)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000797 "creating a copyright license"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000797 "A planned process that has a copyright license as its specified output."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000797 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000797 "copyright license creation"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000797 "Note: for less than 24 hours, this class was a bit more specific to software licenses, but it did not have the equivalent class axiom during that time."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000797 "creating a copyright license"@en)
EquivalentClasses(obo:APOLLO_SV_00000797 ObjectIntersectionOf(obo:OBI_0000011 ObjectSomeValuesFrom(obo:OBI_0000299 obo:APOLLO_SV_00000798)))
SubClassOf(obo:APOLLO_SV_00000797 obo:OBI_0000011)

# Class: obo:APOLLO_SV_00000798 (copyright license)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000798 "copyright license for a creative work"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000798 "A document that is about the legal rights, claims, and obligations of a legal person (person or organization) under copyright law, and how that legal person intends for those rights, claims, and obligations to be handled/managed by users of the creative work to which this document is attached."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000798 "William R. Hogan"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000798 "Can be for any creative work including fiction.  But the license itself is an ICE, and refers to real claims and obligations."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000798 "copyright license"@en)
SubClassOf(obo:APOLLO_SV_00000798 obo:IAO_0000310)

# Class: obo:APOLLO_SV_00000799 (data service software)

