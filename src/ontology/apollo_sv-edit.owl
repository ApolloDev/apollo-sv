AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000062 "Key motivating use case was Synthia synthetic population data."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000062 "primary school student population"@en)
