# Class: obo:APOLLO_SV_00000330 (colonization)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000330 "biological colonization"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000330 "a reproduction of a pathogen of a particular biological taxon inside a host organism of another taxon, without invasion of the tissues of the host."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000330 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000330 "a reproduction of a pathogen of a particular biological taxon inside a host organism of another taxon, without invasion of the tissues of the host."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000330 "Colonization")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000330 "Primary use case is colonization of humans, animals with Staph aureus, but it also covers bacteriuria, transient bactermia, and normal gut flora."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000330 "colonization"@en)
