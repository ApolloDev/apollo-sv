AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000241 "An information content entity specifying the upper and lower limit of a range of ages of continuants."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000241 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000241 "An information content entity specifying the upper and lower limit of a range of ages of continuants."@en)
