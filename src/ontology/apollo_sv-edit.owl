AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000186 "the preferred term is biological contamination to distinguish from things like radiological contamination, contamination of the Gulf of Mexico with oil, the contamination of air with pollution, etc."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000186 "contamination"@en)
