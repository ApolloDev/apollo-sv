# Class: obo:APOLLO_SV_00000238 (host organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000238 "An organism of a particular biological taxon that is the site of reproduction of an organism of a different taxon."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000238 "An organism of a particular biological taxon that is the site of reproduction of an organism of a different taxon."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000238 "host"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000238 "host organism"@en)
