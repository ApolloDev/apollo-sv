# Class: obo:APOLLO_SV_00000335 (chemical resistance to infection)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000335 "chemical resistance to infection"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000335 "A resistance to infection that is conferred by the presence, in sufficient quantity, of a particular molecular entity that is not normally present in the organism."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000335 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000335 "chemoprotection"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000335 "chemoprotective resistance"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000335 "chemotherapeutic resistance to infection"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000335 "A resistance to infection that is conferred by the presence, in sufficient quantity, of a particular molecular entity that is not normally present in the organism."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000335 "As with all dispositions, chemical resistance need not be realized to exist.  The presence of cholorquine confers this disposition even if the person is never bitten by a mosquito, let alone a malaria-laden mosquito."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000335 "Examples: chemoprophylaxis of malaria with chloroquine, treatment of infections with antibiotics, antiviral treatment"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000335 "chemical resistance to infection"@en)
SubClassOf(obo:APOLLO_SV_00000335 obo:APOLLO_SV_00000145)
