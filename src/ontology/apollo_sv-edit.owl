AnnotationAssertion(obo:IAO_0000115 obo:RO_0002229 "inverse of ends with"@en)
AnnotationAssertion(dc:source obo:RO_0002229 "http://purl.obolibrary.org/obo/ro/release/2013-04-28/ro.owl")
AnnotationAssertion(rdfs:label obo:RO_0002229 "ends"@en)
