AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000243 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000243 "A measurement datum that quantifies a temporal region that is occupied by a processual entity."@en)
