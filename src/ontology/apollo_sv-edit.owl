# Class: obo:ENVO_00010483 (environmental material)

AnnotationAssertion(obo:IAO_0000115 obo:ENVO_00010483 "A portion of environmental material is a fiat object which forms the medium or part of the medium of an environmental system.")
AnnotationAssertion(obo:IAO_0000412 obo:ENVO_00010483 "http://purl.obolibrary.org/obo/envo.owl")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:ENVO_00010483 "portion of environmental material")
AnnotationAssertion(oboInOwl:hasOBONamespace obo:ENVO_00010483 "ENVO")
AnnotationAssertion(oboInOwl:id obo:ENVO_00010483 "ENVO:00010483")
AnnotationAssertion(rdfs:comment obo:ENVO_00010483 "Everything under this parent must be a mass noun. All subclasses are to be understood as being composed primarily of the named entity, rather than restricted to that entity. For example, \"ENVO:water\" is to be understood as \"environmental material composed primarly of some CHEBI:water\". This class is currently being aligned to the Basic Formal Ontology. Following this alignment, its definition and the definitions of its subclasses will be revised.")
AnnotationAssertion(rdfs:label obo:ENVO_00010483 "environmental material")
SubClassOf(obo:ENVO_00010483 obo:BFO_0000040)

# Class: obo:ENVO_01000203 (environmental condition)

AnnotationAssertion(obo:IAO_0000114 obo:ENVO_01000203 obo:IAO_0000121)
AnnotationAssertion(obo:IAO_0000115 obo:ENVO_01000203 "An environmental condition is a range of a determinate quality or combination of qualities that are present in an environmental system.")
AnnotationAssertion(obo:IAO_0000412 obo:ENVO_01000203 "http://purl.obolibrary.org/obo/envo/releases/2021-05-14/envo.owl")
AnnotationAssertion(oboInOwl:created_by obo:ENVO_01000203 "ORCID:0000-0002-4366-3088")
AnnotationAssertion(oboInOwl:creation_date obo:ENVO_01000203 "2013-04-07T14:35:18Z")
AnnotationAssertion(oboInOwl:hasDbXref obo:ENVO_01000203 "DOI:10.1186/2041-1480-4-43")
AnnotationAssertion(oboInOwl:inSubset obo:ENVO_01000203 "envoPolar")
AnnotationAssertion(rdfs:comment obo:ENVO_01000203 "A condition defines a restricted range of a given quality or combination of qualities. If an environment class, E, has_condition C, then all qualities listed in C are restricted to the ranges defined in C in E. This is not intended as a logical conditional.")
AnnotationAssertion(rdfs:label obo:ENVO_01000203 "environmental condition")
SubClassOf(obo:ENVO_01000203 obo:PATO_0001018)

