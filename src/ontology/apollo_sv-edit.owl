AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000623 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000623 "A count of cases in an epidemic that spans a shorter interval, such as a particular day or a week."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000623 "Incident case counts are measured according to regular intervals, typically day or week.")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000623 "The count is also nearly always geographically localized, for example, the case count for the state of Pennsylvania or the case count for Waukesha County, Wisconsin."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000623 "incident epidemic case count"@en)
SubClassOf(obo:APOLLO_SV_00000623 obo:APOLLO_SV_00000498)
SubClassOf(obo:APOLLO_SV_00000623 obo:APOLLO_SV_00000649)

# Class: obo:APOLLO_SV_00000624 (count of events occurring in a population)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000624 "A count of processes in which a population and/or its members participate during a given temporal region."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000624 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000624 "A count of certain type of event that occurs within a population, such as deaths, infections, births, and so on during a particular time."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000624 "As the population is typically geographically defined (among other ways), the count is most often constrained to particular location in addition to a given time."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000624 "count of events occurring in a population"@en)
