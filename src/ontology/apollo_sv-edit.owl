# Class: obo:APOLLO_SV_00000036 (normal distribution)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000036 "A continuous parametric probability distribution that is uniform; centered around the mean, parameter μ​; and whose spread of standard deviations, parameter σ​, adheres to the empirical rule."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000036 "A continuous probability distribution in which the parameter μ is the mean or expectation of the distribution and the parameter σ is its standard deviation"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000036 "NormalDistribution")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000036 "normal distribution"@en)
SubClassOf(obo:APOLLO_SV_00000036 obo:APOLLO_SV_00000251)

# Class: obo:APOLLO_SV_00000038 (simulation of exposed organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000038 "A simulation of an infectious agent host that is not contagious and is part of a simulated population."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000038 "A simulated organism in a simulated population that has acquired a particular simulated disease but is not yet able to transmit the disease to another simulated organism."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000038 "simulation of exposed organism"@en)
SubClassOf(obo:APOLLO_SV_00000038 obo:APOLLO_SV_00000034)

# Class: obo:APOLLO_SV_00000039 (simulated population location identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000039 "An identifier that refers to a geographical location to be used as location of a population in a simulation."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000039 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000039 "An identifier referring to geographical location of a simulated population.  Our intent is for the location identifiers to be INCITS codes."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000039 "simulated population location identifier"@en)
SubClassOf(obo:APOLLO_SV_00000039 obo:IAO_0020000)

# Class: obo:APOLLO_SV_00000040 (simulation of infectious organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000040 "A simulation of an infectious organism host that is contagious."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000040 "A simulated organism in a simulated population that has acquired a particular simulated disease and is able to transmit the disease to another simulated organism."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000040 "simulation of infectious organism"@en)
SubClassOf(obo:APOLLO_SV_00000040 obo:APOLLO_SV_00000034)

# Class: obo:APOLLO_SV_00000041 (simulation of recovered organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000041 "A simulated organism in a simulated population that is not susceptible."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000041 "A simulated organism in a simulated population that is neither susceptible, exposed, nor infectious for a particular simulated disease. 
Note that the name for this concept, were it to be named based on its intent, would be ‘immune.’  However, in the practice domain of epidemiology this concept is traditionally termed ‘recovered.’  The problem with the traditional name is that organisms can be considered ‘recovered’ by virtue of having been vaccinated, which differs from lay usage."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000041 "simulation of recovered organism"@en)
EquivalentClasses(obo:APOLLO_SV_00000041 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:APOLLO_SV_00000067 ObjectIntersectionOf(obo:OBI_0100026 ObjectComplementOf(ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000172)))) ObjectSomeValuesFrom(obo:RO_0000056 obo:APOLLO_SV_00000005)))
SubClassOf(obo:APOLLO_SV_00000041 obo:APOLLO_SV_00000034)

# Class: obo:APOLLO_SV_00000042 (simulation of disease)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000042 "A representation of a disposition realized in a represented disease course that at least part of the simulated population is represented as participating in."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000042 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000042 "The disease being simulated."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000042 "disease")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000042 "simulation of disease"@en)
SubClassOf(obo:APOLLO_SV_00000042 obo:APOLLO_SV_00000070)
SubClassOf(obo:APOLLO_SV_00000042 ObjectSomeValuesFrom(obo:BFO_0000051 ObjectIntersectionOf(obo:IAO_0020000 ObjectSomeValuesFrom(obo:IAO_0000219 obo:OGMS_0000031))))

# Class: obo:APOLLO_SV_00000043 (reproduction number)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000043 "The average value of transmissions of the infectious agent from one infected organism to another, resulting in an infection."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000043 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000043 "The number of susceptible organisms that each infected organism infects.  ‘Infects’ carries the same meaning as ‘exposes’ in epidemic simulations such as SEIR simulation."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000043 "ReproductionNumber")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000043 "reproduction number"@en)
SubClassOf(obo:APOLLO_SV_00000043 obo:OBI_0000679)
SubClassOf(obo:APOLLO_SV_00000043 ObjectIntersectionOf(obo:OBI_0000679 ObjectSomeValuesFrom(obo:IAO_0000136 ObjectIntersectionOf(obo:APOLLO_SV_00000115 ObjectSomeValuesFrom(obo:RO_0000057 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:BFO_0000137 obo:PCO_0000001)))))))

# Class: obo:APOLLO_SV_00000044 (nursery school student population)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000044 "Mathias Brochhausen"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000044 "Key motivating use case was Synthia synthetic population data."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000044 "nursery school student population"@en)
EquivalentClasses(obo:APOLLO_SV_00000044 ObjectIntersectionOf(obo:OMRSE_00000023 ObjectAllValuesFrom(obo:RO_0002351 ObjectIntersectionOf(obo:NCBITaxon_9606 ObjectSomeValuesFrom(obo:RO_0000053 obo:OMRSE_00000058) ObjectExactCardinality(1 obo:OMRSE_00000070 ObjectIntersectionOf(obo:OMRSE_00000057 ObjectSomeValuesFrom(obo:RO_0000053 obo:OMRSE_00000059)))))))
SubClassOf(obo:APOLLO_SV_00000044 obo:APOLLO_SV_00000178)

# Class: obo:APOLLO_SV_00000045 (obsolete asymptomatic infection fraction)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000045 "The fraction given to express the probability that an organism will become infected, but stay asymptomatic."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000045 "The fraction of infectious individuals who do not develop symptoms during the course of their infections."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000045 "asymptomatic infection fraction")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000045 "obsolete asymptomatic infection fraction"@en)
AnnotationAssertion(owl:deprecated obo:APOLLO_SV_00000045 "true"^^xsd:boolean)
SubClassOf(obo:APOLLO_SV_00000045 oboInOwl:ObsoleteClass)

# Class: obo:APOLLO_SV_00000046 (vaccine supply schedule)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000046 "An action specification giving the number of doses of vaccine to be made available over a specific time period."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000046 "The counts of vaccine doses that become available in a specific population location during (at the start of would be unambiguous) each simulator time step."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000046 "vaccine supply schedule"@en)
SubClassOf(obo:APOLLO_SV_00000046 obo:APOLLO_SV_00000795)

# Class: obo:APOLLO_SV_00000047 (vaccination administration capacity)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000047 "An action specification giving the number of vaccinations possible in a population during a specific time interval."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000047 "The counts of individuals that could be vaccinated in a population location per time step unit in the absence of any vaccine supply constraints.  It represents the capacity of medical system to vaccinate individuals."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000047 "vaccination administration capacity"@en)
SubClassOf(obo:APOLLO_SV_00000047 obo:APOLLO_SV_00000795)

# Class: obo:APOLLO_SV_00000048 (antiviral treatment efficacy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000048 "The infectious disease treatment efficacy of an antiviral drug."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000048 "The degree to which a particular antiviral drug reduces the probability that a treated individual will have a particular preventable outcome.

Preventable outcomes include but are not limited to infection, infectiousness, symptoms, and hospitalization."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000048 "AntiviralTreatmentEfficacy")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000048 "MB: For DL reasons the easiest way to formalize the definition was to assume only organism that are either host or not immune undergo antiviral treatment. Is that adequate? I assume this'll create problems…"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000048 "antiviral treatment efficacy"@en)
SubClassOf(obo:APOLLO_SV_00000048 obo:APOLLO_SV_00000227)

# Class: obo:APOLLO_SV_00000049 (antiviral efficacy delay)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000049 "The value of the time interval between an organism's taking antivirals against a specific infectious agent and the organism’s losing its infectious agent host role."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000049 "The duration of time (expressed in time steps) between initiation of a particular antiviral treatment to an organism and when the organism becomes non infectious or, if the antiviral is being administered prophylactically, protected from infection."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000049 "antiviral efficacy delay"@en)
SubClassOf(obo:APOLLO_SV_00000049 obo:APOLLO_SV_00000243)

# Class: obo:APOLLO_SV_00000050 (antiviral compliance)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000050 "The fraction expressing the probability that an organism will be consented to receive antiviral treatment when eligible."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000050 "The fraction of individuals in a simulated population that will accept antiviral treatment if offered."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000050 "antiviral cm compliance")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000050 "MB: This class is still awaiting its class restriction. It should be restricted as being about a population that has members that are eligible for an antiviral treatment against the members that are eligible and consented the antiviral treatment. There is a class \"eligibility rule\" in OBI (http://purl.obolibrary.org/obo/OBI_0500026), but it is restricted by definition to studies. I put in an issue in the OBI issue tracker. The consenting process and its specified outcome should be done in d-acts, but needs to be done properly."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000050 "MW: Since the estimates that modelers use are from real populations, I have two questions:
1. Should we distinguish between real and simulated population?
2.  If so, do we want to represent a ‘measured’ antiviral compliance number that is a property of a real population and distinguish it from this number that we are using to study what might happen in a simulated population?

MB: This issue will need to be taken care of in the axiomatization of simulated population"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000050 "antiviral compliance"@en)
SubClassOf(obo:APOLLO_SV_00000050 obo:OBI_0302867)

# Class: obo:APOLLO_SV_00000051 (antiviral supply schedule)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000051 "An action specification giving the number of doses of an antiviral to be made available during a specific time interval."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000051 "Counts of antiviral doses that become available in a specific location per time step unit."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000051 "antiviral supply schedule"@en)
SubClassOf(obo:APOLLO_SV_00000051 obo:APOLLO_SV_00000795)

# Class: obo:APOLLO_SV_00000052 (antiviral administration schedule)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000052 "An action specification that tells the total number of antiviral doses available to be administered to a population during a specific time interval."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000052 "Counts of antiviral doses that can be administered in a specific location per time step unit."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000052 "antiviral administration schedule"@en)
SubClassOf(obo:APOLLO_SV_00000052 obo:APOLLO_SV_00000795)

# Class: obo:APOLLO_SV_00000053 (simulation of organism awaiting control measure)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000053 "A simulated organism that is assumed “eligible, willing and able” to participate with a particular control measure."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000053 "A simulated organism in a simulated population that is “eligible, willing and able” to participate with a particular simulated control measure."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000053 "MB: APOLLO_SV_00000053 and APOLLO_SV_00000058 have not been given a class restriction, since they are not expressible in BFO right now, due to their referring to \"will\". Both classes have been made disjoint in the OWL file, though."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000053 "This class will need more ontological reasoning, since the \"willing\" part of the definition is not representable in BFO to date."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000053 "simulation of organism awaiting control measure"@en)
SubClassOf(obo:APOLLO_SV_00000053 obo:APOLLO_SV_00000034)
DisjointClasses(obo:APOLLO_SV_00000053 obo:APOLLO_SV_00000058)

# Class: obo:APOLLO_SV_00000054 (complete simulator identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000054 "An identifier that refers to a specific simulator."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000054 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000054 "The combination of simulator developer, simulator name, and simulator version, for example “www.psc.edu/FRED/2.0”  The combination is intended to uniquely identify the simulation algorithm that produced output X, given input Y to support scientific audit, error analysis, and reproducibility of results."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000054 "MB: I am not 100% happy with the elucidation. Can't we just say that this is the full identifier identifying the simulator with both its name and its version number?"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000054 "complete simulator identifier"@en)
EquivalentClasses(obo:APOLLO_SV_00000054 ObjectIntersectionOf(obo:IAO_0020000 ObjectSomeValuesFrom(obo:IAO_0000219 obo:APOLLO_SV_00000001)))
SubClassOf(obo:APOLLO_SV_00000054 obo:IAO_0020000)

# Class: obo:APOLLO_SV_00000055 (epidemic simulating)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000055 "A simulating of a disease epidemic or pandemic."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000055 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000055 "the process of simulating a disease epidemic or pandemic. This term is not currently used in Apollo-WS."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000055 "epidemic simulation")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000055 "epidemic simulating"@en)
SubClassOf(obo:APOLLO_SV_00000055 obo:APOLLO_SV_00000005)
SubClassOf(obo:APOLLO_SV_00000055 ObjectIntersectionOf(obo:APOLLO_SV_00000005 ObjectSomeValuesFrom(obo:RO_0000057 obo:APOLLO_SV_00000001)))

# Class: obo:APOLLO_SV_00000056 (hospital patient population census)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000056 "Mathias Brochhausen"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000056 "Motivating use case is to cover Synthia data, and possibly configuration/output of the MRSA simulator in the MIDAS community (CA-MRSA Repast)."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000056 "hospital patient population census"@en)
EquivalentClasses(obo:APOLLO_SV_00000056 ObjectIntersectionOf(obo:APOLLO_SV_00000153 ObjectSomeValuesFrom(obo:IAO_0000136 obo:APOLLO_SV_00000030)))
SubClassOf(obo:APOLLO_SV_00000056 obo:APOLLO_SV_00000153)

# Class: obo:APOLLO_SV_00000058 (simulation of organism not awaiting control measure)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000058 "A simulated organism that is assumed “ineligible, unwilling or unable” to participate with a particular control measure."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000058 "A simulated organism in a simulated population that is “ineligible, unwilling or unable” to participate with a particular simulated control measure."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000058 "MB: APOLLO_SV_00000053 and APOLLO_SV_00000058 have not been given a class restriction, since they are not expressible in BFO right now, due to their referring to \"will\". Both classes have been made disjoint in the OWL file, though."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000058 "This class will need more ontological reasoning, since the \"unwilling\" part of the definition is not representable in BFO to date."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000058 "simulation of organism not awaiting control measure"@en)
SubClassOf(obo:APOLLO_SV_00000058 ObjectIntersectionOf(obo:APOLLO_SV_00000034 ObjectComplementOf(ObjectSomeValuesFrom(obo:RO_0000056 obo:APOLLO_SV_00000029))))

# Class: obo:APOLLO_SV_00000059 (simulation of organism awaiting effect of control measure)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000059 "A simulated organism that  participates in a particular control measure that has not yet been effective."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000059 "This concept represents a simulated organism that has received a control measure such as vaccination in which a period of time must elapse before the benefit of the control measure accrues.  A simulated organism is ‘awaiting efficacy’ if ‘efficacy delay’ (e.g. the concept ‘antiviral efficacy delay’ for the particular simulated control measure is greater than the elapsed time between application of the control measure and the current simulated time."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000059 "simulation of organism awaiting effect of control measure"@en)
SubClassOf(obo:APOLLO_SV_00000059 obo:APOLLO_SV_00000034)

# Class: obo:APOLLO_SV_00000060 (simulation of antiviral control measure)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000060 "The simulation of an antiviral control measure."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000060 "A type of control measure based on administration of chemotherapeutic agents to an infected or high-risk organism that kill or inhibit replication of viruses within a simulated organism."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000060 "antiviral control measure")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000060 "MB: For all the antiviral-related classes I referred to ChEBI: Antiviral class. I wasn't able to use the plug-in though (there was a JAVA heap space error, probably due to the size of ChEBI).
AND (more importantly) I did not re-use any of the ChEBI hierarchy which, even in the BFO version is a mess.
Maybe we need to discuss this."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000060 "simulation of antiviral control measure"@en)
SubClassOf(obo:APOLLO_SV_00000060 obo:APOLLO_SV_00000070)

# Class: obo:APOLLO_SV_00000061 (simulation of vaccination control measure)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000061 "A simulation of a vaccination control measure."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000061 "A type of control measure that uses vaccination to create immunity in simulated organisms to specific pathogens."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000061 "simulation of vaccination control measure")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000061 "simulation of vaccination control measure"@en)
SubClassOf(obo:APOLLO_SV_00000061 obo:APOLLO_SV_00000070)

