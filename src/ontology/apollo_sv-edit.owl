# Class: obo:APOLLO_SV_00000332 (colonization acquisition)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000332 "colonization acquisition"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000332 "a biological process where a pathogen organism of a particular biological taxon enters into a host organism of a particular taxon and begins to undergo reproduction in a location external to tissues of the host"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000332 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000332 "a biological process where a pathogen organism of a particular biological taxon enters into a host organism of a particular taxon and begins to undergo reproduction in a location external to tissues of the host"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000332 "ColonizationAcquisition")
