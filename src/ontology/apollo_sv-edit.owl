AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000030 "Mathias Brochhausen"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000030 "Key motivating use case was Synthia synthetic population data."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000030 "hospital patient population"@en)
