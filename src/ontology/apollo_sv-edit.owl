# Class: obo:APOLLO_SV_00002024 (facultative role)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00002024 "facultative role"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00002024 "A role borne by an organism in virtue of the fact that it is in intimate association with one or more organisms of different species, and is realized by bodily benefit to that organism as an occurrent part of a symbiosis with the other organisms. This bodily benefit takes the place of the organism or some relatively isolated part of the organism realizing some normal homeostasis disposition itself."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00002024 "facultative role"@en)
SubClassOf(obo:APOLLO_SV_00002024 obo:BFO_0000023)

# Class: obo:BFO_0000027 (object aggregate)

AnnotationAssertion(rdfs:comment obo:BFO_0000027 "Definition: A material entity [snap:MaterialEntity] that is a mereological sum of separate object [snap:Object] entities and possesses non-connected boundaries.")
AnnotationAssertion(rdfs:comment obo:BFO_0000027 "Examples: a heap of stones, a group of commuters on the subway, a collection of random bacteria, a flock of geese, the patients in a hospital")
AnnotationAssertion(rdfs:comment obo:BFO_0000027 "Synonyms: substance aggregate")
AnnotationAssertion(rdfs:label obo:BFO_0000027 "object_aggregate")
SubClassOf(obo:BFO_0000027 obo:BFO_0000040)

