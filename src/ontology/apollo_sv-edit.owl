AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000338 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000338 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000338 "An ectosymbiosis that results in harm to all participating organisms."@en)
