AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000196 "ring vaccination individual treatment control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000196 obo:APOLLO_SV_00000136)

# Class: obo:APOLLO_SV_00000197 (agent level population and environment census)

AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000197 "An instance of the an AgentLevel PopulationAndEnvironmentCensus type comprises an AgentLevel PopulationAndEnvironmentCensus Description, which describes the biotic and abiotic ecosystems elements that are counted by the census, and a URL where the census (the counts) can be retrieved."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000197 "agent level population and environment census"@en)
SubClassOf(obo:APOLLO_SV_00000197 obo:APOLLO_SV_00000188)

# Class: obo:APOLLO_SV_00000198 (agent model ecosystem census description)

AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000198 "At present, this class corresponds with an XSD type that contains authentication plus information needed to generate a Synthia synthetic population dataset including (1) geographical location and (2) a list of household characteristics."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000198 "agent model ecosystem census description"@en)
AnnotationAssertion(owl:deprecated obo:APOLLO_SV_00000198 "true"^^xsd:boolean)

# Class: obo:APOLLO_SV_00000199 (compartment model population and environment census)

AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000199 "The Apollo XSD allows us to specify counts of certain subpopulations and abiotic ecosystem elements for a compartmental model (vs. specifying each individual in the population as in agent model population and environment census)."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000199 "compartment model population and environment census"@en)
AnnotationAssertion(owl:deprecated obo:APOLLO_SV_00000199 "true"^^xsd:boolean)

