# Annotation Property: obo:APOLLO_SV_00000319 (NLM ID)

AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000319 "National Library of Medicine Identifier"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000319 "This identifier is the one that the National Library of Medicine uses to identify journals uniquely in PubMed."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000319 "NLM ID"@en)

# Annotation Property: obo:APOLLO_SV_00000320 (ISSN Linking)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000320 "linking ISSN"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000320 "International Standard Serial Number, Linking"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000320 "The linking ISSN is a single number assigned to all formats of a journal.  The online and print versions of a journal, for example, are typically different.  The linking ISSN refers to the journal regardless of format."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000320 "ISSN Linking"@en)

# Annotation Property: obo:APOLLO_SV_00000321 (ISO Title Abbreviation)

AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000321 "Iso Abbr"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000321 "ISO Abbreviations are constructed at NLM to assist NCBI in linking from GenBank to PubMed."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000321 "ISO Title Abbreviation"@en)

# Annotation Property: obo:APOLLO_SV_00000324 (NLM Title Abbreviation)

AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000324 "The abbreviated journal title assigned by the National Library of Medicine.  Typically, it's the ISO title abbreviation without periods."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000324 "NLM Title Abbreviation"@en)

# Annotation Property: obo:APOLLO_SV_00000325 (URI creation date)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000325 "The date on which a URI annotated with this property was created."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000325 "William R. Hogan"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000325 "This is the date that you created the URI that represents something, NOT the date that the thing referenced by the URI was created.

For example, if you create a URI on 2014-09-24 to represent a book published on 1982-10-17, then this annotation property should have the value 2014-09-24.

In other words, this annotation refers to the representation, not the represented thing.

For the 1982-10-17 date, we suggest the dc:created annotation."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000325 "URI creation date"@en)

# Annotation Property: obo:APOLLO_SV_00000329 (author list <annotation>)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000329 "author list"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000329 "William R. Hogan"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000329 "an annotation property for capturing the list of authors on the publication or other document to which the entity to which the annotation is attached refers.  That is, this annotation should be attached only to individuals that represent information content entities, and its values must denote the people that authored the ICE."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000329 "author list <annotation>"@en)

# Annotation Property: obo:APOLLO_SV_00000488 (source code repository URL)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000488 "source code version control repository URL"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000488 "WIlliam R. Hogan"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000488 "This annotation is intended for annotating instances of software application, software module, ontology (artifact), etc. with a uniform resource locator that points to the source code version control repository where they are managed.  Note that for OWL individuals that reference a particular version of the software or ontology, this URL should point to the place in the repository where that version is located, rather than the general main page of the repository."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000488 "source code repository URL"@en)

# Annotation Property: obo:APOLLO_SV_00000523 (human readable synopsis)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000523 "human readable synopsis"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000523 "A comment that summarizes the most relevant or salient features and history of the entity for human readers."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000523 "William R. Hogan"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000523 "human readable synopsis"@en)
SubAnnotationPropertyOf(obo:APOLLO_SV_00000523 rdfs:comment)

