AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000234 "A population of organisms that are all susceptible."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000234 "susceptible population"@en)
EquivalentClasses(obo:APOLLO_SV_00000234 ObjectIntersectionOf(obo:APOLLO_SV_00000516 ObjectAllValuesFrom(obo:RO_0002351 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000172)))))
SubClassOf(obo:APOLLO_SV_00000234 obo:APOLLO_SV_00000516)

# Class: obo:APOLLO_SV_00000235 (immune population)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000235 "A population of organisms that are all immune."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000235 "A population of organisms that are all immune."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000235 "immune population"@en)
SubClassOf(obo:APOLLO_SV_00000235 obo:APOLLO_SV_00000516)

