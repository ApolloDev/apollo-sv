AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000290 "treatment preventable outcome"@en)
SubClassOf(obo:APOLLO_SV_00000290 obo:IAO_0000005)

# Class: obo:APOLLO_SV_00000291 (time delay of treatment detection)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000291 "The duration from the time an individual receives a treatment until the time a system designed to detect that the treatment occurred detects it in a population"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000291 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000291 "The duration from treatment until a treatment surveillance system detects it in a population"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000291 "timeDelayOfTreatmentDetection")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000291 "time delay of treatment detection"@en)
SubClassOf(obo:APOLLO_SV_00000291 obo:APOLLO_SV_00000243)

# Class: obo:APOLLO_SV_00000292 (individual treatment strategy supply schedule unit of measure)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000292 "The unit of measure for the supply schedule of an individual treatment."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000292 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000292 "The unit of measure for the supply schedule of an individual treatment.

For example, 'daily dose'."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000292 "supplyScheduleUnits")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000292 "individual treatment strategy supply schedule unit of measure"@en)
SubClassOf(obo:APOLLO_SV_00000292 obo:UO_0000000)

# Class: obo:APOLLO_SV_00000293 (individual treatment strategy administration capacity unit of measure)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000293 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000293 "The unit of measure for the administration capacity of an individual treatment.

For example, 'daily dose'."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000293 "administrationCapacityUnits"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000293 "individual treatment strategy administration capacity unit of measure"@en)
SubClassOf(obo:APOLLO_SV_00000293 obo:UO_0000000)

# Class: obo:APOLLO_SV_00000294 (agent-based disease transmission model)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000294 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000294 "A disease transmission model that explicitly represents each individual in the population and simulates the acquisition of disease by individuals who do not already have it at simulator time zero."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000294 "agent-based disease transmission model"@en)
SubClassOf(obo:APOLLO_SV_00000294 obo:APOLLO_SV_00000174)

