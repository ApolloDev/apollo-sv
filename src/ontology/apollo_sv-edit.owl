############################
#   Classes
############################

# Class: <http://purl.obolibrary.obo/obo/NCBITaxon_7160> (Aedes albopictus)

AnnotationAssertion(obo:IAO_0000118 <http://purl.obolibrary.obo/obo/NCBITaxon_7160> "Stegomyia albopicta")
AnnotationAssertion(obo:IAO_0000118 <http://purl.obolibrary.obo/obo/NCBITaxon_7160> "forest day mosquito")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.obo/obo/NCBITaxon_7160> "Aedes albopictus"@en)
SubClassOf(<http://purl.obolibrary.obo/obo/NCBITaxon_7160> obo:NCBITaxon_53541)

# Class: obo:APOLLO_SV_00000000 (purely intentional entity)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000000 "A generically dependent continuant which derives its existence and its entire endowment from an intending experience of consciousness (an \"act\") that is laden with determinate, uniformily structured content."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000000 "A generically dependent continuant which derives its existence and its entire endowment from an intending experience of consciousness (an \"act\") that is laden with determinate, uniformily structured content."@en)
AnnotationAssertion(dc:source obo:APOLLO_SV_00000000 "Ingarden, R. (1964) Der Streit um die Existenz der Welt I. Existentalontologie. Max Niemeyer, Tübingen.")
AnnotationAssertion(dc:source obo:APOLLO_SV_00000000 "Ingarden, R. (1965a) Das literarische Kunstwerk. 3. Auflage. Max Niemeyer, Tübingen.")
AnnotationAssertion(dc:source obo:APOLLO_SV_00000000 "Ingarden, R. (1965b) Der Streit um die Existenz der Welt II/1. Formalontologie 1. Teil. Max Niemeyer, Tübingen.")
AnnotationAssertion(dc:source obo:APOLLO_SV_00000000 "Johansson I. (2009) Proof of the existence of universals – and Roman Ingarden's Ontology. Metaphysica. International Journal for Ontology & Metaphysics. 10, 65-87")
AnnotationAssertion(dc:source obo:APOLLO_SV_00000000 "Thomasson AL. \"Ingarden and the Ontology of Cultural Objects.\" In: Chrudziminski A (ed.): Existence, Culture, and Person. The Ontology of Roman Ingarden. Frankfurt: ontos, 2005, 115-136.")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000000 "MB: Right now we represent 'purely intentional entities' as siblings to 'information content entities'. Given their nature I am not entirly sure that this is correct. It seems that both 'information content entity' and 'simulation' are subclass to 'purely intentional entity'."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000000 "purely intentional entity"@en)
SubClassOf(obo:APOLLO_SV_00000000 obo:BFO_0000031)

# Class: obo:APOLLO_SV_00000001 (epidemic model)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000001 "A disease transmission model whose concretization is realized as a simulation of infectious disease epidemic or infectious disease pandemic."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000001 "William Hogan and Michael Wagner")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000001 "An algorithm the concretizations of which models the transmission of transmissible disease."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000001 "epidemic model"@en)
SubClassOf(obo:APOLLO_SV_00000001 obo:APOLLO_SV_00000174)

# Class: obo:APOLLO_SV_00000002 (basic reproduction number)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000002 "The average number of transmissions of an infectious agent from an infectious organism to a susceptible organism within a completely susceptible population."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000002 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000002 "The number of organisms that each infected organism infects in a completely susceptible population during its infectious period."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000002 "basicReproductionNumbers")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000002 "MB: Here we run into the well know DL problem that we cannot specify that the infectious agent that is transmitted is of the same type that the infectious agent the population is susceptible to."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000002 "basic reproduction number"@en)
SubClassOf(obo:APOLLO_SV_00000002 obo:APOLLO_SV_00000043)
SubClassOf(obo:APOLLO_SV_00000002 ObjectIntersectionOf(obo:APOLLO_SV_00000043 ObjectSomeValuesFrom(obo:IAO_0000136 ObjectIntersectionOf(obo:APOLLO_SV_00000115 ObjectSomeValuesFrom(obo:RO_0000057 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:BFO_0000137 obo:APOLLO_SV_00000234)))))))

# Class: obo:APOLLO_SV_00000003 (population immunity survey)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000003 "A population survey that assesses the level of immunity against a particular pathogen in a specified population."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000003 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000003 "A population survey that assesses the level of immunity against a particular pathogen in a specified population."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000003 "Comment from Mike (to do!):
I checked because an infection and immunity census would involve two different census methods.   One would be some kind of disease surveillance that counts infections.  The other is some kind of immunity census process based on seroprevalence studies or vaccination registries."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000003 "population immunity survey"@en)
SubClassOf(obo:APOLLO_SV_00000003 obo:APOLLO_SV_00000152)

# Class: obo:APOLLO_SV_00000005 (simulating of process of type X)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000005 "a planned process that (1) has at least one process part that has as participants representations of participants (in place of those participants) of processes of type X, and where all such process parts substitute for parts of processes of type X, and (2) is carried out for the purpose of planning for processes of type X, learning more about processes of type X, or teaching about processes of type X."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000005 "A process that replaces the essential participants of another type of process with representations of those participants."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000005 "simulating of process of type X")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000005 "For example, in a simulated volcano eruption, representations of lava, lava tubes, vents, etc. take the place of actual lava, lava tubes, vents, etc.

Even in the case of a simulated disaster scenario where actual ambulances, fire trucks, and people participate, representations of catastrophic events and injuries, etc. take the place of real ones."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000005 "simulating of process of type X"@en)
SubClassOf(obo:APOLLO_SV_00000005 obo:OBI_0000011)

# Class: obo:APOLLO_SV_00000006 (simulation requester identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000006 "An identifier that refers to the legal person that commissions a simulation process."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000006 "An identifier that refers to the person or organization who is requesting one or more executions of the simulator software."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000006 "Class was originally created to correspond with a complex type from Apollo XSD v3.1.0."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000006 "simulation requester identifier"@en)
EquivalentClasses(obo:APOLLO_SV_00000006 ObjectIntersectionOf(obo:IAO_0020000 ObjectSomeValuesFrom(obo:IAO_0000219 ObjectIntersectionOf(ObjectUnionOf(obo:NCBITaxon_9606 obo:OBI_0000245) ObjectSomeValuesFrom(obo:APOLLO_SV_00000037 obo:APOLLO_SV_00000005)))))
SubClassOf(obo:APOLLO_SV_00000006 obo:IAO_0020000)

# Class: obo:APOLLO_SV_00000007 (simulation software application)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000007 "A software application that provides a model of a real phenomenon based on a set of mathematical formulas."@en)
AnnotationAssertion(obo:IAO_0000119 obo:APOLLO_SV_00000007 "http://en.wikipedia.org/wiki/Simulation_software")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000007 "A software application that provides a model of a real phenomenon based on a set of mathematical formulas."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000007 "simulator")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000007 "simulation software application"@en)
SubClassOf(obo:APOLLO_SV_00000007 obo:IAO_0000594)

# Class: obo:APOLLO_SV_00000009 (simulator developer identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000009 "An identifier that refers to the legal person that creates and maintains a simulator."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000009 "An identifier that refers to the person or organization who is responsible for the simulator.  It is intended to uniquely identify a person or organization.  That said, we do not plan to control the namespace for simulator developer at this point in development.  We will add our ideas about alternatives at a future date."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000009 "simulator developer identifier"@en)
EquivalentClasses(obo:APOLLO_SV_00000009 ObjectIntersectionOf(obo:IAO_0020000 ObjectSomeValuesFrom(obo:IAO_0000219 ObjectIntersectionOf(ObjectUnionOf(obo:NCBITaxon_9606 obo:OBI_0000245) ObjectSomeValuesFrom(obo:RO_0000056 ObjectIntersectionOf(obo:APOLLO_SV_00000008 ObjectSomeValuesFrom(obo:OBI_0000299 obo:APOLLO_SV_00000007)))))))
SubClassOf(obo:APOLLO_SV_00000009 obo:APOLLO_SV_00000105)

# Class: obo:APOLLO_SV_00000010 (simulator identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000010 "An identifier that refers to all version of a specific simulator."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000010 "An identifier that refers to all versions of a specific simulator, such as “FRED”.  We intend that it uniquely identify a simulator when combined with simulator developer.  For example, the combination www.psc.edu/FRED would differentiate the FRED simulator created by a Pittsburgh organization from another “FRED” simulator maintained elsewhere. The implementation of namespace control for simulator name (i.e., making sure that they don’t use “FRED” twice) is the responsibility of simulator developer."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000010 "simulator identifier"@en)
EquivalentClasses(obo:APOLLO_SV_00000010 ObjectIntersectionOf(obo:IAO_0020000 ObjectSomeValuesFrom(obo:IAO_0000219 obo:APOLLO_SV_00000007)))
SubClassOf(obo:APOLLO_SV_00000010 obo:IAO_0020000)
SubClassOf(obo:APOLLO_SV_00000010 ObjectSomeValuesFrom(obo:BFO_0000050 obo:APOLLO_SV_00000054))

# Class: obo:APOLLO_SV_00000011 (control strategy reactive start time information)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000011 "A control strategy start time information item that is based on a condition that triggers the control strategy."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000011 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000011 "A control strategy start time information item that is based on a condition that triggers the control strategy."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000011 "control strategy reactive start time information"@en)
AnnotationAssertion(owl:deprecated obo:APOLLO_SV_00000011 "true"^^xsd:boolean)

# Class: obo:APOLLO_SV_00000012 (simulation time step value)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000012 "A numeral that is part of a simulation time step action specification."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000012 "A number of time step units in a time step of a simulation.  For example, if the time step is 6 hours, then this value is 6."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000012 "numberOfUnitsOfTimeInOneSimulatorStep")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000012 "simulation time step value"@en)
SubClassOf(obo:APOLLO_SV_00000012 obo:IAO_0000029)

# Class: obo:APOLLO_SV_00000013 (simulator version identifier)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000013 "An identifier that, as part of a complete simulator identifier, refers to one specific version of a simulator software."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000013 "An identifier that refers to a unique version of a simulator. Simulator version distinguishes, for example, version “2.0” from “2.0.b”"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000013 "simulator version identifier"@en)
SubClassOf(obo:APOLLO_SV_00000013 obo:IAO_0020000)
SubClassOf(obo:APOLLO_SV_00000013 ObjectSomeValuesFrom(obo:BFO_0000050 obo:APOLLO_SV_00000054))

# Class: obo:APOLLO_SV_00000014 (simulation time step unit)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000014 "A time unit that is part of a simulation time step action specification."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000014 "A unit of time for each time step of a simulation, such as “hours” or “days”."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000014 "unitOfTimeForSimulatorTimeStep")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000014 "simulation time step unit"@en)
SubClassOf(obo:APOLLO_SV_00000014 obo:UO_0000003)

# Class: obo:APOLLO_SV_00000015 (simulation run length)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000015 "The action specification that specifies the number of time steps a simulation is going to run."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000015 "The number of time steps in a simulator run. For example, if run length is 10 and the time step is 6 hours, then the simulator will simulate a 60-hour period that begins at simulator time zero."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000015 "runLength")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000015 "simulation run length"@en)
SubClassOf(obo:APOLLO_SV_00000015 obo:APOLLO_SV_00000793)
SubClassOf(obo:APOLLO_SV_00000015 ObjectSomeValuesFrom(obo:BFO_0000051 obo:APOLLO_SV_00000068))

# Class: obo:APOLLO_SV_00000016 (infectious period duration)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000016 "A duration of the parts of an infection during which the host bears an infectious disposition in a population of hosts."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000016 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000016 "A period when an individual of a particular species, who is infected with a particular pathogen, is able to infect susceptible organisms of a particular species.

Note that the susceptible and infectious organisms can be of different species."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000016 "infectiousPeriodDuration")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000016 "MB: In order to get the temporal occupation relations I added properties that I renamed with BFO2 URIs."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000016 "infectious period duration"@en)
SubClassOf(obo:APOLLO_SV_00000016 obo:APOLLO_SV_00000243)
SubClassOf(obo:APOLLO_SV_00000016 ObjectSomeValuesFrom(obo:IAO_0000136 ObjectIntersectionOf(obo:BFO_0000038 ObjectSomeValuesFrom(obo:BFO_0000156 obo:APOLLO_SV_00000140))))

# Class: obo:APOLLO_SV_00000017 (latent period duration)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000017 "A duration of the time interval between the host acquiring an infection and the host bearing a contagiousness disposition during the same disease course within a population of hosts."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000017 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000017 "A period during which an organism of a particular species, who is infected with a particular pathogen, is not yet able to infect susceptible organisms of a particular species.  Note that the susceptible and infected organisms can be of different species."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000017 "latentPeriodDuration")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000017 "MB: In order to get the temporal occupation relations I added properties that I renamed with BFO2 URIs"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000017 "The duration of the period between when an organism becomes infected and when it becomes infectious."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000017 "latent period duration"@en)
SubClassOf(obo:APOLLO_SV_00000017 obo:APOLLO_SV_00000243)
SubClassOf(obo:APOLLO_SV_00000017 ObjectSomeValuesFrom(obo:IAO_0000136 ObjectIntersectionOf(obo:BFO_0000038 ObjectSomeValuesFrom(obo:BFO_0000156 obo:APOLLO_SV_00000118))))

# Class: obo:APOLLO_SV_00000018 (count of simulated susceptible population)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000018 "Mathias Brochhausen")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000018 "count of simulated susceptible population"@en)
SubClassOf(obo:APOLLO_SV_00000018 obo:APOLLO_SV_00000617)

# Class: obo:APOLLO_SV_00000019 (count of simulated exposed population)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000019 "Mathias Brochhausen")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000019 "count of simulated exposed population"@en)
SubClassOf(obo:APOLLO_SV_00000019 obo:APOLLO_SV_00000617)

# Class: obo:APOLLO_SV_00000020 (count of simulated contagious population)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000020 "Mathias Brochhausen")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000020 "count of simulated contagious population"@en)
SubClassOf(obo:APOLLO_SV_00000020 obo:APOLLO_SV_00000617)

# Class: obo:APOLLO_SV_00000021 (count of simulated resistant population)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000021 "Mathias Brochhausen")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000021 "count of simulated resistant population"@en)
SubClassOf(obo:APOLLO_SV_00000021 obo:APOLLO_SV_00000617)

# Class: obo:APOLLO_SV_00000022 (count of simulated population)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000022 "The count of (simulated organisms) in a simulated population."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000022 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000022 "The number of simulated organisms in a simulated population.  The number does not have to be an integer."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000022 "MW: I know this causes problems with our set-theoretic definition.  Unfortunately the compartmental models produce fractional counts at each of their time steps, including the final step.  

Any ideas?  I’ve considered and rejected allowing individual organisms to be fractional.  Perhaps if we just replace the term “cardinality” in the definition with ‘computed size’"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000022 "count of simulated population"@en)
SubClassOf(obo:APOLLO_SV_00000022 obo:APOLLO_SV_00000617)
SubClassOf(obo:APOLLO_SV_00000022 ObjectIntersectionOf(obo:APOLLO_SV_00000617 ObjectSomeValuesFrom(obo:IAO_0000136 obo:APOLLO_SV_00000031)))

# Class: obo:APOLLO_SV_00000023 (vaccination dose schedule)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000023 "An action specification comprising the number of doses and their timing for a vaccination of an individual organism against a specific infectious agent."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000023 "A vaccination schedule specifies the intended timing of initial and subsequent booster doses of vaccine for an individual organism."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000023 "vaccination dose schedule"@en)
SubClassOf(obo:APOLLO_SV_00000023 obo:APOLLO_SV_00000084)

# Class: obo:APOLLO_SV_00000024 (vaccination compliance)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000024 "The fraction expressing the probability that an organism who is eligible according to a particular vaccination policy will be consented for that vaccination."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000024 "The fraction of individuals in a population who are eligible according to a particular vaccination policy and will accept vaccination assuming no supply constraint.")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000024 "MB: This class is still awaiting its class restriction. It should be restricted as being about a population that has members that are eligible for a vaccination against the members that are eligible and consented the vaccination. There is a class \"eligibility rule\" in OBI (http://purl.obolibrary.org/obo/OBI_0500026), but it is restricted by definition to studies. I put in an issue in the OBI issue tracker. The consenting process and its specified outcome should be done in d-acts, but needs to be done properly."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000024 "MW: I still see enough similarities at the abstract level among some control measures that we might add the concepts “Control measure compliance”, “Control measure efficacy”  and “control measure efficacy delay.”    We could then post-coordinate particular control measures such as vaccine.

It is worth noting that there are control measures such as closing schools that are not applied at the individual level.   We have not represented those control measures yet."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000024 "vaccination compliance"@en)
SubClassOf(obo:APOLLO_SV_00000024 obo:OBI_0302867)

# Class: obo:APOLLO_SV_00000025 (vaccination efficacy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000025 "The infectious disease treatment efficacy of a vaccine."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000025 "The degree to which a particular vaccination reduces the probability that a vaccinated individual will have a particular vaccination preventable outcome."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000025 "vaccinationEfficacies")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000025 "Notes: 
1. Apollo-SV does not distinguish between ‘vaccine efficacy’ and ‘vaccine effectiveness.’
2. Apollo-SV also considers the use of ‘vaccine’ in both terms a misnomer"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000025 "need to generate class restriction.  Something like:

'is realized by' some (processual_entity and (has_participant some ('Anatomical structure' and ('is physical basis of' some 'protective resistance'))

we'd also like to say that the protective resistance disposition began to exist during the process.  

can't recall whether we should use process or processual_entity for future BFO compatibility."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000025 "vaccination efficacy"@en)
SubClassOf(obo:APOLLO_SV_00000025 obo:APOLLO_SV_00000227)

# Class: obo:APOLLO_SV_00000026 (facility survey)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000026 "A planned process involving counting numbers of facilities in a specific region."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000026 "A planned process involving counting numbers of facilities in a specific region."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000026 "facility survey"@en)
SubClassOf(obo:APOLLO_SV_00000026 obo:OBI_0000011)

