# Class: obo:APOLLO_SV_00000327 (quarantine control strategy)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000327 "quarantine control strategy"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000327 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000327 "An infectious disease control strategy whereby organisms who have had contact with infectious organisms but are not symptomatic or otherwise known to be infectious are prevented from having contact with other susceptible organisms."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000327 "quarantine control strategy"@en)
