# Class: obo:APOLLO_SV_00000114 (infection)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000114 "A reproduction of a pathogen organism of a particular biological taxon in a tissue of a host organism from another taxon."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000114 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000114 "infection process"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000114 "process of infection"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000114 "A process of reproduction of a particular pathogen species inside some tissue of a particular host species."@en)
AnnotationAssertion(dc:creator obo:APOLLO_SV_00000114 "M. Brochhausen"@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000114 "infection is reproduction of a pathogen inside some tissue of a host.  By associating infection with the classes latent period and infectious period, which are associated with specific pathogen species and host species, Apollo-SV defines infection further as reproduction of a particular pathogen taxon inside some tissue of a particular host taxon."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000114 "infection"@en)
EquivalentClasses(obo:APOLLO_SV_00000114 ObjectIntersectionOf(obo:APOLLO_SV_00000651 ObjectSomeValuesFrom(obo:BFO_0000066 ObjectIntersectionOf(obo:UBERON_0000479 ObjectSomeValuesFrom(obo:BFO_0000050 obo:OBI_0100026)))))
SubClassOf(obo:APOLLO_SV_00000114 obo:APOLLO_SV_00000651)
SubClassOf(obo:APOLLO_SV_00000114 ObjectSomeValuesFrom(obo:RO_0002087 obo:APOLLO_SV_00000115))

# Class: obo:APOLLO_SV_00000115 (infection acquisition)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000115 "The biological process of pathogen organism(s) of a particular biological taxon entering (the tissues of the body of) a host organism of another taxon from a contagious host or a contaminated thing and reproducing using host resources."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000115 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000115 "A process where a susceptible organism from a particular species becomes infected by a particular pathogen.  The infection is acquired from an infected organism of a particular species or from a contaminated thing.  

Note that the susceptible and infectious organisms can be of different species."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000115 "InfectionAcquisition")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000115 "Apollo-SV defines infection acquisition rather than infection transmission, which is the direction of movement of a pathogen in current use.  The Apollo-SV conceptualization is simpler when accounting for infections acquired from contaminated things.
The likelihood of acquisition is expressed by parameters such as the basic reproduction rate and transmission coefficient.   
An infection is acquired from an infectious organism or a contaminated thing."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000115 "Cannot acquire from colonized host directly - contamination results from colonized or contaminated thing and new host picks it up from contaminated thing."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000115 "infection acquisition"@en)
EquivalentClasses(obo:APOLLO_SV_00000115 ObjectIntersectionOf(obo:GO_0044409 ObjectSomeValuesFrom(obo:BFO_0000066 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000172))) ObjectSomeValuesFrom(obo:RO_0000057 ObjectUnionOf(obo:APOLLO_SV_00000166 ObjectIntersectionOf(obo:APOLLO_SV_00000238 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000182)))) ObjectSomeValuesFrom(obo:RO_0002411 obo:APOLLO_SV_00000114)))
SubClassOf(obo:APOLLO_SV_00000115 obo:GO_0044409)

