# Class: obo:APOLLO_SV_00000237 (pathogen)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000237 "An organism of a particular biological taxon that is the bearer of an infectious dispositions towards an organism of a different particular biological taxon."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000237 "An organism, virus, or prion that can infect another organism."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000237 "pathogen")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000237 "pathogen"@en)
