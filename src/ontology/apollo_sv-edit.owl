AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000240 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000240 "A information content entity that specifies the date of a census."@en)
