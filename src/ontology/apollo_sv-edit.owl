SubClassOf(obo:APOLLO_SV_00000305 obo:APOLLO_SV_00000304)

# Class: obo:APOLLO_SV_00000306 (infection in ecosystem)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000306 "infection in an ecosystem"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000306 "A process comprised of numerous infections and infection acquisitions with a particular pathogen in one or more populations of hosts."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000306 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000306 "A process of ongoing infection and infection acquisition in individuals in one or more populations in an ecosystem."@en)
