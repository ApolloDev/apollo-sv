AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000525 "William R. Hogan"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000525 "compiled software code"@en)
SubClassOf(obo:APOLLO_SV_00000525 obo:IAO_0000010)

