AnnotationAssertion(obo:IAO_0000116 obo:ENVO_01000797 "This class is to be populated by inference.")
AnnotationAssertion(obo:IAO_0000412 obo:ENVO_01000797 "http://purl.obolibrary.org/obo/envo.owl")
AnnotationAssertion(oboInOwl:hasNarrowSynonym obo:ENVO_01000797 "gas")
AnnotationAssertion(rdfs:label obo:ENVO_01000797 "gaseous environmental material"@en)
SubClassOf(obo:ENVO_01000797 obo:ENVO_00010483)

# Class: obo:ENVO_01001078 (weather)

AnnotationAssertion(obo:IAO_0000115 obo:ENVO_01001078 "Environmental variability which inheres in an astronomical body part or in outer space.")
AnnotationAssertion(obo:IAO_0000412 obo:ENVO_01001078 "http://purl.obolibrary.org/obo/envo/releases/2021-05-14/envo.owl")
AnnotationAssertion(oboInOwl:hasDbXref obo:ENVO_01001078 "https://en.wikipedia.org/wiki/Space_weather")
AnnotationAssertion(oboInOwl:hasDbXref obo:ENVO_01001078 "https://en.wikipedia.org/wiki/Weather")
AnnotationAssertion(rdfs:comment obo:ENVO_01001078 "This class refers to all weather, including atmospheric and space weather. Please use a subclass for more specificity.")
AnnotationAssertion(rdfs:label obo:ENVO_01001078 "weather"@en)
SubClassOf(obo:ENVO_01001078 obo:ENVO_01001081)

# Class: obo:ENVO_01001079 (atmospheric weather)

AnnotationAssertion(obo:IAO_0000115 obo:ENVO_01001079 "Weather which inheres in an atmosphere.")
AnnotationAssertion(obo:IAO_0000412 obo:ENVO_01001079 "http://purl.obolibrary.org/obo/envo/releases/2021-05-14/envo.owl")
AnnotationAssertion(oboInOwl:hasDbXref obo:ENVO_01001079 "https://en.wikipedia.org/wiki/Weather")
AnnotationAssertion(rdfs:comment obo:ENVO_01001079 "This class refers to the common usage of \"weather\", referencing the state of a (part of) an astronomical body's atmosphere.")
AnnotationAssertion(rdfs:label obo:ENVO_01001079 "atmospheric weather"@en)
SubClassOf(obo:ENVO_01001079 obo:ENVO_01001078)

# Class: obo:ENVO_01001081 (environmental variability)

AnnotationAssertion(obo:IAO_0000115 obo:ENVO_01001081 "A condition which inheres in an environmental system by virtue of that system undergoing variation in its composition, the distribution of the qualities its components bear, and/or in the processes which occur within it and which it participates in.")
AnnotationAssertion(obo:IAO_0000412 obo:ENVO_01001081 "http://purl.obolibrary.org/obo/envo/releases/2021-05-14/envo.owl")
AnnotationAssertion(rdfs:comment obo:ENVO_01001081 "This class is very general, but the nature of environmental variability is indeed quite variable. This class may be refined once we have more subclasses to consider.")
AnnotationAssertion(rdfs:label obo:ENVO_01001081 "environmental variability"@en)
SubClassOf(obo:ENVO_01001081 obo:ENVO_01000203)

# Class: obo:ENVO_02500000 (environmental system process)

AnnotationAssertion(obo:IAO_0000412 obo:ENVO_02500000 "http://purl.obolibrary.org/obo/envo.owl")
AnnotationAssertion(rdfs:comment obo:ENVO_02500000 "Should environmental feature become something more towards a disposition, the assert would be updated to something like \"has participant (environmental system or (material entity and has disposition some environmental feature))\". There are several issues surrounding the reconcilliation of environmental feature and environmental system, both theoretical and practical.")
AnnotationAssertion(rdfs:label obo:ENVO_02500000 "environmental system process"@en)
SubClassOf(obo:ENVO_02500000 obo:BFO_0000015)

