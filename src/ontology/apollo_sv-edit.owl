AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000226 "This is probably a 'process profile' according to BFO2"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000226 "infectiousness profile"@en)
SubClassOf(obo:APOLLO_SV_00000226 obo:BFO_0000144)

# Class: obo:APOLLO_SV_00000227 (infectious disease treatment efficacy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000227 "The disposition of one or more portions of material entity, when administered to a susceptible organism by a certain route and according to a certain schedule, to produce a structural change in an organism of a specific species, whereby this structural change serves as the physical basis of a protective resistance disposition."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000227 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000227 "The disposition of one or more portions of material entity, when administered to a susceptible organism by a certain route and according to a certain schedule, to produce a structural change in an organism of a specific species, whereby this structural change serves as the physical basis of a protective resistance disposition."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000227 "TreatmentEfficacy")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000227 "need to generate class restriction.  Something like:

'is realized by' some (processual_entity and (has_participant some ('Anatomical structure' and ('is physical basis of' some 'protective resistance'))

we'd also like to say that the protective resistance disposition began to exist during the process.  

can't recall whether we should use process or processual_entity for future BFO compatibility."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000227 "infectious disease treatment efficacy"@en)
SubClassOf(obo:APOLLO_SV_00000227 obo:BFO_0000016)

# Class: obo:APOLLO_SV_00000228 (border control strategy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000228 "A travel-related infectious disease control strategy that has an action specification that is realized in restricting movement of organisms across international borders."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000228 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000228 "A travel-related infectious disease control strategy that has an action specification that is realized in restricting movement of organisms across international borders."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000228 "BorderControlMeasure")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000228 "border control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000228 obo:APOLLO_SV_00000486)

# Class: obo:APOLLO_SV_00000229 (place closure control strategy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000229 "an infectious disease control strategy that has an action specification that is realized in closing facilities where organisms congregate during times when the facilities normally would be open."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000229 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000229 "An infectious disease control strategy that attempts to prevent infection of susceptible host organisms in a population by preventing potentially infectious contacts (for a particular pathogen) among the organisms in the population."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000229 "PlaceClosureControlMeasure")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000229 "place closure control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000229 obo:APOLLO_SV_00000086)

# Class: obo:APOLLO_SV_00000230 (case isolation control strategy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000230 "an infectious disease control strategy that has an action specification that is realized in isolating organsims who are infectious."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000230 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000230 "An infectious disease control strategy that isolates infected and/or infectious individuals in a population from most or all potentially infectious contacts with susceptible individuals."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000230 "CaseQuarantineControlMeasure")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000230 "case isolation control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000230 obo:APOLLO_SV_00000086)

# Class: obo:APOLLO_SV_00000231 (travel restriction control strategy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000231 "A travel-related infectious disease control strategy whose action specification is realized in restricting travel of organims from one ecosystem to another ecosystem"@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000231 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000231 "A travel-related infectious disease control strategy whose action specification is realized in restricting travel of organims from one geographical region to another"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000231 "TravelRestrictionControlMeasure")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000231 "travel restriction control strategy"@en)
SubClassOf(obo:APOLLO_SV_00000231 obo:APOLLO_SV_00000486)

# Class: obo:APOLLO_SV_00000232 (clade name)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000232 "A taxonomy identifier that denotes a group of organisms or groups of organisms based on common ancestors."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000232 "Mathias Brochhausen"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000232 "A reference to a group or groups of organisms that are based on common ancestry."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000232 "cladeName")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000232 "Some regard a clade to be a single branch on the tree of life. [http://en.wikipedia.org/wiki/Clade]"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000232 "clade name"@en)
SubClassOf(obo:APOLLO_SV_00000232 obo:APOLLO_SV_00000509)

# Class: obo:APOLLO_SV_00000233 (infected population)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000233 "A population of only infected members of one species."@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000233 "A population of only infected members of one species."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000233 "infected population"@en)
