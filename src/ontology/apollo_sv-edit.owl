AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000295 "A unit of measure for a threshold in a reactive infectious disease control strategy."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000295 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000295 "A unit of measure for a threshold in a reactive infectious disease control strategy."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000295 "unitOfMeasureForThreshold")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000295 "reactive control strategy threshold unit of measure"@en)
SubClassOf(obo:APOLLO_SV_00000295 obo:UO_0000000)

# Class: obo:APOLLO_SV_00000296 (case definition)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000296 "An information content entity that specifies the criteria that an organism must meet to be considered to be in some abnormal state."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000296 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000296 "A specification of the criteria an organism must meet to be considered to be in some abnormal state.

The abnormal state could be having a disease, carrier status, a syndrome, a structural abnormality (e.g., congenital heart defect), and so on."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000296 "CaseDefinition")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000296 "case definition"@en)
SubClassOf(obo:APOLLO_SV_00000296 obo:IAO_0000030)

# Class: obo:APOLLO_SV_00000297 (obsolete quarantine period)

AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000297 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000297 "A period during which an infectious host organism is isolated from contact with other organisms in the ecosystem as part of a quarantine control strategy."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000297 "obsolete quarantine period"@en)
AnnotationAssertion(owl:deprecated obo:APOLLO_SV_00000297 "true"^^xsd:boolean)

# Class: obo:APOLLO_SV_00000298 (epidemic)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000298 "A process whose beginning is demarcated by accelerating infection acquisition by one or more host species of a particular pathogen in a particular location and whose end is demarcated by the time when the rate of infection acquisition becomes constant."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000298 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000298 "epidemic of infection"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000298 "A process whose beginning is demarcated by accelerating infection acquisition by one or more host species of a particular pathogen in a particular location and whose end is demarcated by the time when the rate of of infection acquisition becomes constant.

The constant rate may be zero.  The period of an epidemic may be defined using statistical criteria based on incidence rates or causal models based on their fit to incidence data."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000298 "Epidemic")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000298 "An example of multiple host species is foot and mouth disease (such as the 2001 epidemic in the UK, see: http://www.sciencemag.org/content/292/5519/1155.long) and swine flu.  The foot and mouth disease epidemic affected sheep, pigs, and cattle."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000298 "epidemic"@en)
SubClassOf(obo:APOLLO_SV_00000298 obo:APOLLO_SV_00000306)
SubClassOf(obo:APOLLO_SV_00000298 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000118 obo:APOLLO_SV_00000114) ObjectSomeValuesFrom(obo:BFO_0000118 obo:APOLLO_SV_00000115)))

# Class: obo:APOLLO_SV_00000299 (immune organism that acts like it is immune)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000299 "An immune organism that acts as if it is immune (i.e., it does not seek vaccination or avoid contact with infectious organisms)."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000299 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000299 "An organism of a particular species who is immune to infection with a pathogen of a particular species, and that acts as if it is immune (that is, it does not seek vaccination, avoid contact with infectious organisms, etc.)"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000299 "immuneAndActsLikeImmune")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000299 "immune organism that acts like it is immune"@en)
SubClassOf(obo:APOLLO_SV_00000299 obo:APOLLO_SV_00000206)

# Class: obo:APOLLO_SV_00000300 (immune organism that acts like it is not immune)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000300 "An immune organism that acts as if it is NOT immune (i.e., it seeks vaccination and/or avoids contact with infectious organisms)."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000300 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000300 "An organism of a particular species who is immune to infection with a pathogen of a particular species, and that acts as if it is NOT immune (that is, it does seeks vaccination, avoids contact with infectious organisms, etc.)"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000300 "immuneButActsLikeNotImmune")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000300 "immune organism that acts like it is not immune"@en)
SubClassOf(obo:APOLLO_SV_00000300 obo:APOLLO_SV_00000206)

# Class: obo:APOLLO_SV_00000301 (naturally-acquired active immune resistance)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000301 "An immune resistance to infection that is causally preceded by an infection and an immune response to that infection with the production of antibodies to antigens from the pathogen population participating in the infection."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000301 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000301 "An immune resistance to infection that is causally preceded by an infection and an immune response to that infection with the production of antibodies to antigens from the pathogen population participating in the infection."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000301 "naturally-acquired active immune resistance"@en)
SubClassOf(obo:APOLLO_SV_00000301 obo:APOLLO_SV_00000151)

# Class: obo:APOLLO_SV_00000302 (recovered organism)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000302 "An organism that is the bearer of a naturally-acquired, active immune resistance to infection."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000302 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000302 "An organism that has recovered from infection with a particular pathogen, is no longer infectious to other organisms of any species, and is not able to be infected again with that pathogen."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000302 "recovered"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000302 "recovered organism"@en)
