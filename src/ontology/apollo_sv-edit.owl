AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000369 "Example: marine worms of genus Riftia and their endosymbiotic bacteria"@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000369 "obligatory endosymbiotic mutualism"@en)
EquivalentClasses(obo:APOLLO_SV_00000369 ObjectIntersectionOf(obo:APOLLO_SV_00000367 ObjectSomeValuesFrom(obo:BFO_0000055 ObjectIntersectionOf(obo:BFO_0000034 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:BFO_0000137 obo:OBI_0100026) ObjectSomeValuesFrom(obo:RO_0000052 obo:UBERON_0000061))))))
