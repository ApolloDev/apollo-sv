AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000369 "An endosymbiotic mutualism that realizes a biological function that inheres in some proper part of at least one of the organisms participating."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000369 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000369 "William R. Hogan")
