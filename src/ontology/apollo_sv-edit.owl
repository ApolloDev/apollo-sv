ObjectPropertyRange(obo:APOLLO_SV_00000037 ObjectUnionOf(obo:BFO_0000004 obo:BFO_0000015 obo:IAO_0000030))

# Object Property: obo:APOLLO_SV_00000057 (instantiates)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000057 "A relation between to particulars such that aRb where b can be any kind of entity while the second is a universal. b instantiates a at some times."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000057 "Barry Smith, Waclaw Kusnierczyk, Daniel Schober, Werner Ceusters, “Towards a Reference Terminology for Ontology Research and Development in the Biomedical Domain”, O. Bodenreider, ed., Proceedings of KR-MED, 2006, 57-66. Also available online at: http://ceur-ws.org/Vol-222.")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000057 "instantiates"@en)
AsymmetricObjectProperty(obo:APOLLO_SV_00000057)
IrreflexiveObjectProperty(obo:APOLLO_SV_00000057)
ObjectPropertyDomain(obo:APOLLO_SV_00000057 obo:BFO_0000001)

