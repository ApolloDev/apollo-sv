AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000200 "PopulationStrataDefinition")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000200 "population strata definition"@en)
SubClassOf(obo:APOLLO_SV_00000200 obo:IAO_0000030)

