AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000472 "age-dependent fecundity reduction"@en)
SubClassOf(obo:APOLLO_SV_00000472 obo:OBI_0001554)

# Class: obo:APOLLO_SV_00000473 (carrying capacity per house)

