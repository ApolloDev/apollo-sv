AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000451 "affinity for buildings"@en)
SubClassOf(obo:APOLLO_SV_00000451 obo:APOLLO_SV_00000470)

# Class: obo:APOLLO_SV_00000452 (linear distance travelled between oviposits)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000452 "An epidemic simulator action specification that specifies the linear distance a female mosquito will travel to find the next oviposition site after depositing some of its eggs at the previous one."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000452 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000452 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000452 "An epidemic simulator action specification that specifies the linear distance a female mosquito will travel to find the next oviposition site after depositing some of its eggs at the previous one."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000452 "straightTravelAfterOviposit")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000452 "linear distance travelled between oviposits"@en)
SubClassOf(obo:APOLLO_SV_00000452 obo:APOLLO_SV_00000793)

# Class: obo:APOLLO_SV_00000453 (eggs per brood)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000453 "An average value that specifies the number of eggs produced during one reproductive cycle for each individual female within a population."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000453 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000453 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000453 "An average value that specifies the number of eggs produced during one reproductive cycle for each individual female within a population."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000453 "eggsPerBrood")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000453 "eggs per brood"@en)
SubClassOf(obo:APOLLO_SV_00000453 obo:OBI_0000679)

# Class: obo:APOLLO_SV_00000454 (efficacy)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000454 "A disposition of an organism to (i) undergo some bodily benefit that (ii) is triggered by a planned process."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000454 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000454 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000454 "A disposition of an organism to (i) undergo some bodily benefit that (ii) is triggered by a planned process."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000454 "efficacy")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000454 "We often say in natural language it is the efficacy of the triggering planned process such as vaccination. However, processes do not have properties such as roles, dispositions, functions, qualities in BFO. And this is also not a process profile, because it is not the process of a quality changing values (determinates) over time. Nevertheless, it is natural to classify efficacies based on the type of triggering process because that is what differentiates what happens when they are realized. For example, a vaccination efficacy will be realized through different processes than a quarantine efficacy. For individual treatments, the triggering process is a treatment (as defined by OGMS)."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000454 "efficacy"@en)
SubClassOf(obo:APOLLO_SV_00000454 obo:BFO_0000016)

# Class: obo:APOLLO_SV_00000455 (prodromal period)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000455 "A temporal part of a disease course that itself has a temporal part of becoming symptomatic, followed by another temporal part that is characterized by the organism experiencing mild, non-disease-specific symptoms."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000455 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000455 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000455 "A temporal part of a disease course that itself has a temporal part of becoming symptomatic, followed by another temporal part that is characterized by the organism experiencing mild, non-disease-specific symptoms."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000455 "prodromal period"@en)
SubClassOf(obo:APOLLO_SV_00000455 obo:BFO_0000015)

# Class: obo:APOLLO_SV_00000456 (fulminant period)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000456 "A temporal part of a disease course that 1) itself has a temporal part of becoming severely symptomatic, 2) terminates in either death or some bodily harm, and 3) has a sudden onset and short duration."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000456 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000456 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000456 "A temporal part of a disease course that 1) itself has a temporal part of becoming severely symptomatic, 2) terminates in either death or some bodily harm, and 3) has a sudden onset and short duration."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000456 "Although it is often or even typically preceded by a prodromal period, it is not always the case. Therefore \"immediately preceded by some prodromal period\" cannot be a necessary condition."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000456 "fulminant period"@en)
SubClassOf(obo:APOLLO_SV_00000456 obo:BFO_0000015)

# Class: obo:APOLLO_SV_00000457 (vector bite probability)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000457 "The probablity that a female mosquito feeds on or probes the host given an interaction between the mosquito and the host that brings them within a certain proximity (the bite radius)."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000457 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000457 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000457 "The probability that a female mosquito feeds on or probes the host given an interaction between the mosquito and the host that brings them within a certain proximity (the bite radius)."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000457 "biteProbability")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000457 "vector bite probability"@en)
SubClassOf(obo:APOLLO_SV_00000457 obo:APOLLO_SV_00000470)

# Class: obo:APOLLO_SV_00000458 (male mosquito mating radius)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000458 "A length measurement datum that specifies the radius of a circle, which is centered at a male vector organism, for which there is some probability that it will mate with a female mosquito."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000458 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000458 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000458 "A length measurement datum that specifies the radius of a circle, which is centered at a male vector organism, for which there is some probability that it will mate with a female mosquito."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000458 "maleMatingRadius")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000458 "male mosquito mating radius"@en)
SubClassOf(obo:APOLLO_SV_00000458 obo:IAO_0000408)

# Class: obo:APOLLO_SV_00000459 (infectious disease control strategy cover radius)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000459 "A length measurement datum that specifies the radius of a circle that defines the geographical region in which some infectious disease control strategy will be implemented."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000459 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000459 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000459 "A length measurement datum that specifies the radius of a circle that defines the geographical region in which some infectious disease control strategy will be implemented."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000459 "coverRadius")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000459 "infectious disease control strategy cover radius"@en)
SubClassOf(obo:APOLLO_SV_00000459 obo:IAO_0000408)

