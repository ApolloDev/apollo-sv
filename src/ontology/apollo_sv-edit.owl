AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000331 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000331 "an infection in an ecosystem occurring in one population of organisms"@en)
