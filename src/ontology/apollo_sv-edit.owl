# Class: obo:APOLLO_SV_00000031 (simulated population)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000031 "A simulation of a population or populations of organisms of a particular biological taxon that simulates a particular type of event or types of event that occur in a specified time interval."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000031 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000031 "A simulated population is a set of simulated organisms.  The set can be null (e.g., the set of 200 year-old H. sapiens).  A simulated population can include more than one species, in which case it may be convenient to define each species as a simulated population and form the overall simulated population by set union.  Similarly, it may be convenient to define sociodemographic or geographic strata within a simulated population as simulated populations and obtain the overall simulated population by set union.  See examples in “Programmer’s Guide, page x)"@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000031 "simulatorReferencablePopulation")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000031 "simulated population"@en)
EquivalentClasses(obo:APOLLO_SV_00000031 ObjectIntersectionOf(ObjectSomeValuesFrom(obo:APOLLO_SV_00000067 obo:PCO_0000000) ObjectSomeValuesFrom(obo:RO_0000056 obo:APOLLO_SV_00000005)))
SubClassOf(obo:APOLLO_SV_00000031 obo:APOLLO_SV_00000070)

# Class: obo:APOLLO_SV_00000032 (count)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000032 "A measurement datum that is the output of counting."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000032 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000032 "A measurement datum that is the output of counting."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000032 "count")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000032 "count"@en)
EquivalentClasses(obo:APOLLO_SV_00000032 ObjectIntersectionOf(obo:IAO_0000027 ObjectSomeValuesFrom(obo:OBI_0000312 obo:APOLLO_SV_00000033)))
SubClassOf(obo:APOLLO_SV_00000032 obo:IAO_0000109)

# Class: obo:APOLLO_SV_00000033 (counting)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000033 "The planned process of finding the number of elements in a finite set of objects."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000033 "Mathias Brochhausen")
AnnotationAssertion(obo:IAO_0000119 obo:APOLLO_SV_00000033 "http://en.wikipedia.org/wiki/Counting")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000033 "The planned process of finding the number of elements in a finite set of objects."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000033 "counting"@en)

# Class: obo:APOLLO_SV_00000034 (simulation of organism)

AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000034 "a simulation that is about an organism")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000034 "simulation of organism"@en)
