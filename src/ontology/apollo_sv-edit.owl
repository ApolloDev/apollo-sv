# Class: obo:APOLLO_SV_00000403 (transmission tree)

AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000403 "A data structure that represents, for a particular infection in ecosystem, a subset of infected organisms and for each infected organism in the subset except the first one infected temporally, its infection acquisition from an infected host as a machine-readable link to that infected host."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000403 "Matthew Diller")
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000403 "William R. Hogan")
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000403 "A data structure that represents, for a particular infection in ecosystem, a subset of infected organisms and for each infected organism in the subset except the first one infected temporally, its infection acquisition from an infected host as a machine-readable link to that infected host."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000403 "TransmissionTree")
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000403 "Because a set A is a subset of itself, we capture the possibility that all infected organisms in the epidemic are represented in the tree."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000403 "This definition allows for multiple trees in an epidemic because we did not require that the first case infected temporally be the index case, although the ideal situation is that there is one tree for the epidemic that includes the index case."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000403 "transmission tree"@en)
SubClassOf(obo:APOLLO_SV_00000403 obo:OBI_0000658)

# Class: obo:APOLLO_SV_00000404 (infectiousness)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000404 "infectious disposition"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000404 "A disposition inhering in an organism of a particular biological taxon that is realized only by the organism participating in an infection as the reproducing organism inside another organism of a different particular biological taxon."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000404 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000404 "A disposition inhering in an organism of a particular biological taxon that is realized only by the organism participating in an infection as the reproducing organism inside another organism of a different particular biological taxon."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000404 "The disposition of Influenza A virus H3N2 subtype to infect human beings, the disposition of Plasmodium vivax to infect mosquitos and humans, the disposition of foot and mouth disease virus to infect cloven-hooved animals (sheep, cows, pigs, etc.)."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000404 "infectiousness"@en)
EquivalentClasses(obo:APOLLO_SV_00000404 ObjectIntersectionOf(obo:BFO_0000016 ObjectSomeValuesFrom(obo:RO_0000052 obo:OBI_0100026) ObjectAllValuesFrom(obo:BFO_0000054 obo:APOLLO_SV_00000114)))
SubClassOf(obo:APOLLO_SV_00000404 obo:BFO_0000016)

# Class: obo:APOLLO_SV_00000405 (potentially infectious contacting)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000405 "potentially infectious contact process"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000405 "A biological process that brings the organism into sufficiently close physical proximity to a pathogen population, either in or on a contaminated thing or an infectious host, such that the organism is likely but not certain to acquire an infection with the pathogen."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000405 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000405 "potentially infectious contact"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000405 "A biological process that brings the organism into sufficiently close physical proximity to a pathogen population, either in or on a contaminated thing or an infectious host, such that the organism is likely but not certain to acquire an infection with the pathogen."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000405 "potentially infectious contacting"@en)
SubClassOf(obo:APOLLO_SV_00000405 obo:GO_0008150)

# Class: obo:APOLLO_SV_00000406 (potentially infectious contact role)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000406 "potentially infectous contact role"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000406 "A role borne by an organism that is realized in a potentially infectious contact process."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000406 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000406 "contact role"@en)
AnnotationAssertion(obo:IAO_0000118 obo:APOLLO_SV_00000406 "infectious contact role"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000406 "A role borne by an organism that is realized in a potentially infectious contact process."@en)
AnnotationAssertion(rdfs:comment obo:APOLLO_SV_00000406 "The organism bearing this role is the organism at risk for acquiring an infection when the role is realized.  Also, this role differentiates participants in a process when there are two organisms participating, so it only begins to exist during its realization, justifying its existential restriction."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000406 "potentially infectious contact role"@en)
EquivalentClasses(obo:APOLLO_SV_00000406 ObjectIntersectionOf(obo:BFO_0000023 ObjectSomeValuesFrom(obo:BFO_0000054 obo:APOLLO_SV_00000405)))
SubClassOf(obo:APOLLO_SV_00000406 obo:BFO_0000023)

# Class: obo:APOLLO_SV_00000407 (contacted organism)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000407 "potentially infectious contact organism"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000407 "An organism that is the bearer of a potentially infectious contact role during a potentially infectious contact process."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000407 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000407 "An organism that has been exposed to a pathogen by coming into close physical proximity with either an infectious host or a contaminated thing."@en)
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000407 "contacted organism"@en)
EquivalentClasses(obo:APOLLO_SV_00000407 ObjectIntersectionOf(obo:OBI_0100026 ObjectSomeValuesFrom(obo:RO_0000053 obo:APOLLO_SV_00000406)))
SubClassOf(obo:APOLLO_SV_00000407 obo:OBI_0100026)

# Class: obo:APOLLO_SV_00000408 (contact definition)

AnnotationAssertion(obo:IAO_0000111 obo:APOLLO_SV_00000408 "potentially infectious contact definition"@en)
AnnotationAssertion(obo:IAO_0000115 obo:APOLLO_SV_00000408 "An information content entity that specifies which kinds of processes involving an interaction between a given organism and either (1) another, potentially infectious organism or (2) a contaminated environment have a sufficiently high probability of resultling in an infection acquisition by the organism to be of interest to an outbreak investigation."@en)
AnnotationAssertion(obo:IAO_0000117 obo:APOLLO_SV_00000408 "William R. Hogan"@en)
AnnotationAssertion(obo:IAO_0000600 obo:APOLLO_SV_00000408 "An information content entity that specifies which kinds of processes involving an interaction between a given organism and either (1) another, potentially infectious organism or (2) a contaminated environment have a sufficiently high probability of resultling in an infection acquisition by the organism to be of interest to an outbreak investigation."@en)
AnnotationAssertion(apollo_sv:APOLLO_SV_0000040 obo:APOLLO_SV_00000408 "ContactDefinition")
AnnotationAssertion(rdfs:label obo:APOLLO_SV_00000408 "contact definition"@en)
SubClassOf(obo:APOLLO_SV_00000408 obo:IAO_0000030)

