# Object Property: <http://purl.obolibrary.org/obo/OBIB_0000732> (owns)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/OBIB_0000732> "Mathias Brochhausen")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000600> <http://purl.obolibrary.org/obo/OBIB_0000732> "This is a primitive relation. This relation is the foundation to the owners right to have the owned entity at his/her full disposal."@en)
AnnotationAssertion(<http://purl.org/dc/elements/1.1/source> <http://purl.obolibrary.org/obo/OBIB_0000732> "Reinach, A. Sämtliche Werke. Texkritische Ausgabe, München: Philosophia Verlag, 1989, p.189-204.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/OBIB_0000732> "owns"@en)
